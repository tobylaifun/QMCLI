{
  "tasks": {
    "dev": "deno run --allow-all cli.ts",
    "build": "deno run --allow-all deno-build.ts build",
    "buildexe": "deno run --allow-all deno-build.ts exe"
  },
  "imports": {
    "adm-zip": "npm:adm-zip@^0.5.16",
    "chalk": "npm:chalk@^5.4.1",
    "cli-progress": "npm:cli-progress@^3.12.0",
    "commander": "npm:commander@^13.1.0",
    "deepmerge-ts": "npm:deepmerge-ts@^7.1.4",
    "js-yaml": "npm:js-yaml@^4.1.0",
    "@inquirer/prompts": "npm:@inquirer/prompts@^7.3.1"
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "strict": true,
    "noImplicitOverride": false
  }
}